{
  "version": 2,
  "accounts": {
    "default-send": {
      "provider": "qq",
      "identity": {
        "email": "your_qq@qq.com",
        "login_user": "your_qq@qq.com",
        "display_name": "Your Name"
      },
      "auth": {
        "mode": "auth_code",
        "storage": "config_file",
        "secret": "<QQ_AUTH_CODE_HERE>",
        "keyring_key": null
      },
      "servers": {
        "imap": { "host": "imap.qq.com", "port": 993, "security": "ssl" },
        "smtp": { "host": "smtp.qq.com", "port": 465, "security": "ssl" }
      },
      "proxy": null
    }
  }
}
